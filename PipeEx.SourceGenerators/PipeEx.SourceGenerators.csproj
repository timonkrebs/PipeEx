<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Roslyn incremental source generators that replace the former GenerateSources.sh
    shell script. The generators run at compile time and emit the TupleDestructuring
    classes directly into the consuming PipeEx assemblies, so there are no committed
    *.g.cs files to keep in sync.
  -->
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>

    <!-- This project is a build-time tool only; it is never restored or published as a package. -->
    <IsPackable>false</IsPackable>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
  </PropertyGroup>

  <ItemGroup>
    <!-- PrivateAssets="all" keeps Roslyn out of the consuming projects' dependency graph. -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.8.0" PrivateAssets="all" />
  </ItemGroup>

</Project>
